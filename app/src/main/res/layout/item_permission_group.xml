<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/padding_medium"
    android:layout_marginVertical="@dimen/padding_very_small"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
    app:cardElevation="0dp"
    app:strokeColor="?attr/colorOutlineVariant"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/padding_medium"
        android:paddingVertical="@dimen/padding_small">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/icon"
            android:layout_width="@dimen/premium_icon_48"
            android:layout_height="@dimen/premium_icon_48"
            android:background="?attr/colorSecondaryContainer"
            android:contentDescription="@null"
            android:importantForAccessibility="no"
            android:padding="@dimen/premium_space_12"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.AppTheme.CircleComponent"
            app:tint="?attr/colorOnSecondaryContainer"
            tools:src="@drawable/ic_cctv_off" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/padding_medium"
            android:layout_weight="1"
            android:orientation="vertical">

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                tools:text="Camera" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/premium_space_4"
                android:maxLines="2"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="?attr/colorOnSurfaceVariant"
                tools:text="Apps that can take photos and record video." />

        </LinearLayout>

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/granted_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/padding_small"
            android:background="@drawable/permission_count_badge_background"
            android:paddingHorizontal="@dimen/padding_small"
            android:paddingVertical="@dimen/padding_very_small"
            android:textAppearance="?attr/textAppearanceLabelLarge"
            android:textColor="?attr/colorOnPrimaryContainer"
            tools:text="3/27" />

        <androidx.appcompat.widget.AppCompatImageView
            android:layout_width="@dimen/premium_icon_20"
            android:layout_height="@dimen/premium_icon_20"
            android:layout_marginStart="@dimen/premium_space_8"
            android:contentDescription="@null"
            android:importantForAccessibility="no"
            android:src="@drawable/ic_next"
            app:tint="?attr/colorOnSurfaceVariant" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
