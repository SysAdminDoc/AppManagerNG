<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipToPadding="false"
    android:overScrollMode="ifContentScrolls"
    android:scrollIndicators="top|bottom"
    tools:ignore="UnusedAttribute">

    <androidx.appcompat.widget.LinearLayoutCompat
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/premium_space_20"
        android:paddingTop="@dimen/premium_space_12"
        android:paddingBottom="@dimen/premium_space_16">

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/optimization_scope"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/premium_space_8"
            android:lineSpacingExtra="1dp"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?attr/colorOnSurfaceVariant"
            tools:text="This will queue runtime optimization for 4 selected apps." />

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/dexopt_compiler_section_title"
            android:textAppearance="?attr/textAppearanceLabelMedium"
            android:textColor="?attr/colorPrimary" />

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/premium_space_4"
            android:layout_marginBottom="@dimen/premium_space_12"
            android:lineSpacingExtra="1dp"
            android:text="@string/dexopt_compiler_section_summary"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/compiler_filter_layout"
            style="@style/Widget.AppTheme.TextInputLayout.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/premium_space_20"
            android:hint="@string/select_a_dex2oat_compiler_filter"
            app:hintAnimationEnabled="true"
            app:hintEnabled="true">

            <io.github.muntashirakon.widget.MaterialAutoCompleteTextView
                android:id="@+id/compiler_filter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textNoSuggestions"
                android:maxLines="1"
                tools:text="@tools:sample/full_names" />

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/dexopt_options_section_title"
            android:textAppearance="?attr/textAppearanceLabelMedium"
            android:textColor="?attr/colorPrimary" />

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/premium_space_4"
            android:layout_marginBottom="@dimen/premium_space_8"
            android:lineSpacingExtra="1dp"
            android:text="@string/dexopt_options_section_summary"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/compile_layouts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/optimize_option_compile_layouts" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/compile_layouts_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/premium_space_16"
            android:layout_marginBottom="@dimen/premium_space_8"
            android:lineSpacingExtra="1dp"
            android:text="@string/dexopt_compile_layouts_summary"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/clear_profile_data"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/optimize_option_clear_profile_data" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/clear_profile_data_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/premium_space_16"
            android:layout_marginBottom="@dimen/premium_space_8"
            android:lineSpacingExtra="1dp"
            android:text="@string/dexopt_clear_profile_data_summary"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/check_profiles"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/optimize_option_check_profiles" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/check_profiles_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/premium_space_16"
            android:layout_marginBottom="@dimen/premium_space_8"
            android:lineSpacingExtra="1dp"
            android:text="@string/dexopt_check_profiles_summary"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/force_compilation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/optimize_option_force_compilation" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/force_compilation_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/premium_space_16"
            android:layout_marginBottom="@dimen/premium_space_8"
            android:lineSpacingExtra="1dp"
            android:text="@string/dexopt_force_compilation_summary"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/force_dexopt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/optimize_option_force_dexopt" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/force_dexopt_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/premium_space_16"
            android:lineSpacingExtra="1dp"
            android:text="@string/dexopt_force_dexopt_summary"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?attr/colorOnSurfaceVariant" />

    </androidx.appcompat.widget.LinearLayoutCompat>
</ScrollView>
