<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Widget.AppTheme.CardView.ListItem"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="?attr/listItemMarginHorizontal"
    android:layout_marginTop="@dimen/padding_small"
    android:layout_marginBottom="@dimen/padding_very_small">

    <androidx.appcompat.widget.LinearLayoutCompat
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="?attr/listItemPaddingHorizontal"
        android:paddingVertical="@dimen/padding_medium">

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/action_previous"
                style="@style/Widget.AppTheme.Button.IconButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:layout_weight="0"
                android:contentDescription="@string/goto_previous"
                android:paddingVertical="@dimen/padding_small"
                app:icon="@drawable/ic_previous"
                app:iconSize="20dp" />

            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/screen_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="false"
                    android:gravity="center"
                    android:textAppearance="@style/TextAppearance.AppTheme.DisplaySmall"
                    android:textColor="?attr/colorOnSurface"
                    tools:text="1 hr 20 mins" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_very_small"
                    android:focusable="false"
                    android:gravity="center"
                    android:textAppearance="@style/TextAppearance.AppTheme.TitleSmall"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    tools:text="Today" />

            </androidx.appcompat.widget.LinearLayoutCompat>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/action_next"
                style="@style/Widget.AppTheme.Button.IconButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:layout_weight="0"
                android:contentDescription="@string/next"
                android:paddingVertical="@dimen/padding_small"
                app:icon="@drawable/ic_next"
                app:iconSize="20dp" />

        </androidx.appcompat.widget.LinearLayoutCompat>

        <io.github.muntashirakon.AppManager.usage.BarChartView
            android:id="@+id/bar_chart"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:layout_marginTop="@dimen/padding_medium"
            android:layout_weight="0"
            android:importantForAccessibility="yes"
            app:gridLineCount="4" />

    </androidx.appcompat.widget.LinearLayoutCompat>

</com.google.android.material.card.MaterialCardView>
