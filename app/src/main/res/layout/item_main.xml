<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Widget.AppTheme.CardView.ListItem.Outlined"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="?attr/listItemMarginHorizontal"
    android:layout_marginVertical="@dimen/main_list_card_margin_vertical"
    android:checkable="true"
    android:clickable="true"
    android:focusable="true">

    <androidx.appcompat.widget.LinearLayoutCompat
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:baselineAligned="false"
        android:minHeight="@dimen/main_list_min_height"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/padding_medium"
        android:paddingVertical="@dimen/main_list_padding_vertical">

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="@dimen/main_list_icon_column_width"
            android:layout_height="match_parent"
            android:layout_marginEnd="@dimen/main_list_icon_margin_end"
            android:gravity="top|center_horizontal"
            android:orientation="vertical">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/icon"
                android:layout_width="@dimen/main_list_icon_size"
                android:layout_height="@dimen/main_list_icon_size"
                android:layout_gravity="center_horizontal"
                android:contentDescription="@string/str_logo"
                tools:srcCompat="@mipmap/ic_launcher_round" />

        </androidx.appcompat.widget.LinearLayoutCompat>

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:paddingEnd="@dimen/main_list_title_badge_padding_end"
                    android:textAppearance="?android:attr/textAppearanceListItem"
                    tools:ignore="RtlSymmetry"
                    tools:text="@string/app_name" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/favorite_icon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end|top"
                    android:contentDescription="@string/main_list_debuggable_indicator"
                    android:src="@drawable/item_favorite" />

            </FrameLayout>

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/packageName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="middle"
                android:maxLines="1"
                android:textAppearance="?attr/textAppearanceBodySmall"
                tools:text="io.github.muntashirakon.AppManager" />

            <androidx.appcompat.widget.LinearLayoutCompat
                android:id="@+id/status_badge_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding_very_small"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/backup_indicator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/padding_very_small"
                    android:background="@drawable/badge_background"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:maxLines="1"
                    android:maxWidth="@dimen/main_list_badge_max_width"
                    android:minHeight="@dimen/main_list_badge_min_height"
                    android:minWidth="@dimen/main_list_badge_min_width"
                    android:paddingHorizontal="@dimen/main_list_badge_padding_horizontal"
                    android:paddingVertical="@dimen/main_list_badge_padding_vertical"
                    android:text="@string/backup"
                    android:textAppearance="?attr/textAppearanceLabelSmall"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:visibility="gone"
                    tools:visibility="visible" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tracker_indicator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/padding_very_small"
                    android:background="@drawable/badge_background"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:maxLines="1"
                    android:maxWidth="@dimen/main_list_badge_max_width"
                    android:minHeight="@dimen/main_list_badge_min_height"
                    android:minWidth="@dimen/main_list_badge_min_width"
                    android:paddingHorizontal="@dimen/main_list_badge_padding_horizontal"
                    android:paddingVertical="@dimen/main_list_badge_padding_vertical"
                    android:textAppearance="?attr/textAppearanceLabelSmall"
                    android:visibility="gone"
                    tools:text="3 trackers"
                    tools:visibility="visible" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/perm_indicator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/badge_background"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:maxLines="1"
                    android:maxWidth="@dimen/main_list_badge_max_width"
                    android:minHeight="@dimen/main_list_badge_min_height"
                    android:minWidth="@dimen/main_list_badge_min_width"
                    android:paddingHorizontal="@dimen/main_list_badge_padding_horizontal"
                    android:paddingVertical="@dimen/main_list_badge_padding_vertical"
                    android:textAppearance="?attr/textAppearanceLabelSmall"
                    android:visibility="gone"
                    tools:text="3/8 perms"
                    tools:visibility="visible" />

            </androidx.appcompat.widget.LinearLayoutCompat>

            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding_very_small"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/date"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    tools:text="@tools:sample/date/mmddyy" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/shareid"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/padding_small"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:gravity="end"
                    android:maxLines="1"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    tools:text="@tools:sample/us_zipcodes" />

            </androidx.appcompat.widget.LinearLayoutCompat>

            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding_very_small"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/version"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    tools:text="v3.0.0" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/isSystem"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/padding_small"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    tools:text="User" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/size"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/padding_small"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    tools:text="SDK 30" />

            </androidx.appcompat.widget.LinearLayoutCompat>

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/sha"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="middle"
                android:maxLines="1"
                android:textAppearance="?attr/textAppearanceBodySmall"
                tools:text="SHA256withRSA" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/issuer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="middle"
                android:maxLines="1"
                android:textAppearance="?attr/textAppearanceBodySmall"
                tools:ignore="SmallSp"
                tools:text="CN=Android,OU=Android" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/backup_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textAppearance="?attr/textAppearanceBodySmall"
                tools:ignore="SmallSp"
                tools:text="@tools:sample/lorem[6]" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/backup_info_ext"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textAppearance="?attr/textAppearanceBodySmall"
                tools:ignore="SmallSp"
                tools:text="APK+Data" />

        </androidx.appcompat.widget.LinearLayoutCompat>

    </androidx.appcompat.widget.LinearLayoutCompat>

</com.google.android.material.card.MaterialCardView>
