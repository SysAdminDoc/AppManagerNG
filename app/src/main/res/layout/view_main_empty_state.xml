<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:paddingHorizontal="@dimen/padding_very_large"
    android:paddingVertical="@dimen/padding_large"
    tools:visibility="visible">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/empty_state_icon"
        android:layout_width="@dimen/main_empty_icon_container_size"
        android:layout_height="@dimen/main_empty_icon_container_size"
        android:alpha="0.86"
        android:background="@drawable/main_empty_icon_background"
        android:contentDescription="@null"
        android:importantForAccessibility="no"
        android:padding="@dimen/main_empty_icon_padding"
        android:src="@drawable/ic_package"
        app:tint="?attr/colorOnSecondaryContainer" />

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/empty_state_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/padding_large"
        android:gravity="center"
        android:text="@string/main_empty_title_no_apps"
        android:textAppearance="?attr/textAppearanceTitleMedium"
        android:textColor="?attr/colorOnSurface"
        tools:text="@string/main_empty_title_no_matches" />

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/empty_state_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/padding_small"
        android:gravity="center"
        android:maxWidth="@dimen/main_empty_summary_max_width"
        android:text="@string/main_empty_message_no_apps"
        android:textAppearance="?attr/textAppearanceBodyMedium"
        android:textColor="?attr/colorOnSurfaceVariant"
        tools:text="@string/main_empty_message_no_matches" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/empty_state_action"
        style="@style/Widget.AppTheme.Button.FilledTonalButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/padding_large"
        android:text="@string/refresh"
        app:icon="@drawable/ic_refresh" />

</androidx.appcompat.widget.LinearLayoutCompat>
