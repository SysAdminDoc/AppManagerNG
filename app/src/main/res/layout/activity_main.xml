<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/coordinator_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="io.github.muntashirakon.AppManager.main.MainActivity">

    <io.github.muntashirakon.widget.AppBarLayout
        android:id="@+id/appbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="true"
        app:liftOnScroll="true"
        app:liftOnScrollTargetViewId="@+id/item_list">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@null"
            tools:menu="@menu/activity_main_actions" />

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progress_linear"
            style="@style/Widget.AppTheme.LinearProgressIndicator"
            android:indeterminate="true"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <HorizontalScrollView
            android:id="@+id/quick_filter_scroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="@dimen/padding_small"
            android:paddingBottom="@dimen/padding_very_small"
            android:paddingTop="@dimen/padding_very_small"
            android:scrollbars="none"
            android:fillViewport="true">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/quick_filter_group"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleLine="true"
                app:chipSpacingHorizontal="@dimen/padding_very_small">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_sort"
                    style="@style/Widget.AppTheme.Chip.MainSuggestion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sort"
                    android:checkable="false"
                    app:chipIcon="@drawable/ic_sort"
                    app:chipIconVisible="true"
                    app:closeIconVisible="false" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_guide"
                    style="@style/Widget.AppTheme.Chip.MainSuggestion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checkable="false"
                    android:text="@string/guide"
                    app:chipIcon="@drawable/ic_information_circle"
                    app:chipIconVisible="true"
                    app:closeIconVisible="false" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_user"
                    style="@style/Widget.AppTheme.Chip.MainFilter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/filter_user_apps"
                    android:checkable="true" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_system"
                    style="@style/Widget.AppTheme.Chip.MainFilter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/filter_system_apps"
                    android:checkable="true" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_frozen"
                    style="@style/Widget.AppTheme.Chip.MainFilter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/filter_frozen_apps"
                    android:checkable="true" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_running"
                    style="@style/Widget.AppTheme.Chip.MainFilter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/filter_running_apps"
                    android:checkable="true" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_backups"
                    style="@style/Widget.AppTheme.Chip.MainFilter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/filter_apps_with_backups"
                    android:checkable="true" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_stopped"
                    style="@style/Widget.AppTheme.Chip.MainFilter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/filter_force_stopped_apps"
                    android:checkable="true" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_trackers"
                    style="@style/Widget.AppTheme.Chip.MainFilter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/filter_apps_with_trackers"
                    android:checkable="true" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_rules"
                    style="@style/Widget.AppTheme.Chip.MainFilter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/filter_apps_with_rules"
                    android:checkable="true" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_granted_perms"
                    style="@style/Widget.AppTheme.Chip.MainFilter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/filter_apps_with_granted_perms"
                    android:checkable="true" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_clear_filters"
                    style="@style/Widget.AppTheme.Chip.MainSuggestion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/clear_filters"
                    android:visibility="gone"
                    app:closeIconVisible="true"
                    android:checkable="false" />

            </com.google.android.material.chip.ChipGroup>

        </HorizontalScrollView>

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/list_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/padding_small"
            android:layout_marginBottom="@dimen/padding_small"
            android:layout_marginTop="@dimen/padding_very_small"
            android:background="@drawable/main_status_background"
            android:drawablePadding="@dimen/padding_small"
            android:gravity="center_vertical"
            android:minHeight="@dimen/main_status_min_height"
            android:paddingHorizontal="@dimen/padding_medium"
            android:paddingVertical="@dimen/padding_small"
            android:lineSpacingExtra="@dimen/main_status_line_spacing"
            android:text="@string/main_status_loading"
            android:textAppearance="?attr/textAppearanceLabelMedium"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:visibility="gone"
            tools:visibility="visible" />

    </io.github.muntashirakon.widget.AppBarLayout>

    <io.github.muntashirakon.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:focusable="false"
        app:layout_behavior="com.google.android.material.appbar.AppBarLayout$ScrollingViewBehavior">

        <FrameLayout
            android:id="@+id/main_list_content"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <io.github.muntashirakon.widget.RecyclerView
                android:id="@+id/item_list"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:fitsSystemWindows="true"
                android:focusable="false"
                android:paddingBottom="@dimen/padding_large"
                android:paddingTop="@dimen/padding_very_small"
                android:scrollbars="none"
                app:fastScrollerEnabled="true"
                tools:listitem="@layout/item_main" />

            <include
                android:id="@android:id/empty"
                layout="@layout/view_main_empty_state"
                android:visibility="gone" />

        </FrameLayout>

    </io.github.muntashirakon.widget.SwipeRefreshLayout>

    <io.github.muntashirakon.widget.MultiSelectionView
        android:id="@+id/selection_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="true"
        android:focusable="false"
        app:menu="@menu/activity_main_selection_actions" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
