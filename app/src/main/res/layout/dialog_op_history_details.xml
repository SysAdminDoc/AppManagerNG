<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipToPadding="false">

    <androidx.appcompat.widget.LinearLayoutCompat
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/padding_medium"
        android:paddingTop="@dimen/padding_small"
        android:paddingBottom="@dimen/padding_medium">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/op_history_detail_header"
            style="@style/Widget.AppTheme.V2.Card.Header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:contentPadding="@dimen/premium_space_16">

            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <androidx.appcompat.widget.LinearLayoutCompat
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:layout_width="@dimen/premium_icon_40"
                        android:layout_height="@dimen/premium_icon_40"
                        android:background="?attr/colorTertiaryContainer"
                        android:contentDescription="@null"
                        android:importantForAccessibility="no"
                        android:padding="@dimen/premium_space_8"
                        android:src="@drawable/ic_history"
                        app:shapeAppearanceOverlay="@style/ShapeAppearance.AppTheme.CircleComponent"
                        app:tint="?attr/colorOnTertiaryContainer" />

                    <androidx.appcompat.widget.LinearLayoutCompat
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/premium_space_12"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/op_history_detail_title"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:maxLines="2"
                            android:textAppearance="?attr/textAppearanceTitleMedium"
                            android:textColor="?attr/colorOnSurface"
                            android:textIsSelectable="true"
                            tools:text="Force stop selected apps" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/op_history_detail_summary"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/premium_space_4"
                            android:textAppearance="?attr/textAppearanceBodySmall"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textIsSelectable="true"
                            tools:text="Batch operations · High risk · 3 targets · ADB" />

                    </androidx.appcompat.widget.LinearLayoutCompat>

                </androidx.appcompat.widget.LinearLayoutCompat>

                <androidx.appcompat.widget.LinearLayoutCompat
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/premium_space_12"
                    android:orientation="horizontal">

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/op_history_detail_status"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/badge_background"
                        android:ellipsize="end"
                        android:gravity="center"
                        android:maxLines="1"
                        android:minHeight="@dimen/main_list_badge_min_height"
                        android:paddingHorizontal="@dimen/main_list_badge_padding_horizontal"
                        android:paddingVertical="@dimen/main_list_badge_padding_vertical"
                        android:textAppearance="?attr/textAppearanceLabelSmall"
                        tools:ignore="SmallSp"
                        tools:text="@string/op_history_status_success" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/op_history_detail_risk"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/padding_small"
                        android:layout_weight="1"
                        android:background="@drawable/badge_background"
                        android:ellipsize="end"
                        android:gravity="center"
                        android:maxLines="1"
                        android:minHeight="@dimen/main_list_badge_min_height"
                        android:paddingHorizontal="@dimen/main_list_badge_padding_horizontal"
                        android:paddingVertical="@dimen/main_list_badge_padding_vertical"
                        android:textAppearance="?attr/textAppearanceLabelSmall"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        tools:ignore="SmallSp"
                        tools:text="@string/op_history_risk_high" />

                </androidx.appcompat.widget.LinearLayoutCompat>

                <androidx.appcompat.widget.LinearLayoutCompat
                    android:id="@+id/op_history_detail_action_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/premium_space_12"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/op_history_detail_open_target"
                        style="@style/Widget.AppTheme.Button.FilledTonalButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/op_history_open_target"
                        app:icon="@drawable/ic_open_in_new"
                        app:iconGravity="textStart" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/op_history_detail_rerun"
                        style="@style/Widget.AppTheme.Button.FilledTonalButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/padding_small"
                        android:layout_weight="1"
                        android:text="@string/op_history_action_rerun"
                        app:icon="@drawable/ic_replay"
                        app:iconGravity="textStart" />

                </androidx.appcompat.widget.LinearLayoutCompat>

            </androidx.appcompat.widget.LinearLayoutCompat>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/op_history_detail_body_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_large"
            android:text="@string/op_history_detail_full_details"
            android:textAppearance="?attr/textAppearanceTitleSmall"
            android:textColor="?attr/colorOnSurface" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/op_history_detail_body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_small"
            android:background="@drawable/main_status_background"
            android:lineSpacingExtra="@dimen/main_status_line_spacing"
            android:padding="@dimen/padding_medium"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="?attr/colorOnSurface"
            android:textIsSelectable="true"
            tools:text="@tools:sample/lorem/random" />

    </androidx.appcompat.widget.LinearLayoutCompat>

</ScrollView>
