<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="?android:attr/listPreferredItemPaddingStart"
    android:paddingEnd="?android:attr/listPreferredItemPaddingEnd"
    android:baselineAligned="false"
    android:layout_marginTop="@dimen/padding_large"
    android:layout_marginBottom="@dimen/padding_very_small"
    android:gravity="center_vertical"
    android:layout_marginHorizontal="?attr/listItemMarginHorizontal">

    <View
        android:layout_width="@dimen/preference_category_indicator_width"
        android:layout_height="@dimen/preference_category_indicator_height"
        android:layout_marginEnd="@dimen/preference_category_indicator_margin_end"
        android:background="@drawable/preference_category_indicator" />

    <RelativeLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:paddingTop="@dimen/padding_small"
        android:paddingBottom="@dimen/padding_very_small">

        <com.google.android.material.textview.MaterialTextView
            android:id="@android:id/title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="start"
            android:textAlignment="viewStart"
            android:textAppearance="?attr/preferenceCategoryTitleTextAppearance"
            android:textColor="?attr/preferenceCategoryTitleTextColor"
            tools:text="@tools:sample/lorem[10]" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@android:id/summary"
            android:ellipsize="end"
            android:maxLines="2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@android:id/title"
            android:layout_alignLeft="@android:id/title"
            android:layout_alignStart="@android:id/title"
            android:layout_gravity="start"
            android:layout_marginTop="@dimen/padding_very_small"
            android:textAlignment="viewStart"
            android:textAppearance="?attr/textAppearanceListItemSecondary"
            tools:text="@tools:sample/lorem[10]" />

    </RelativeLayout>
</androidx.appcompat.widget.LinearLayoutCompat>
